---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Resume | codewithnaman">
  <Header />
  <main class="resume-page">
    <section class="page-header">
      <div class="container">
        <h1>📄 Resume</h1>
        <p>Download my resume or view it below.</p>
      </div>
    </section>
    <section class="resume-content">
      <div class="container">
        <div class="resume-card glass-card">
          <div class="resume-preview">
            <div class="resume-info">
              <h2>Naman Gupta</h2>
              <p class="title">Senior Software Engineer & Trainer</p>
              <p class="contact">📧 codewithnaman@gmail.com | 📍 Bangalore, India</p>
              <p class="summary">
                9+ years of experience in software development specializing in Java, Spring Framework,
                Kafka, and AWS Cloud. Passionate about clean code, mentoring, and building scalable systems.
              </p>
            </div>
            <div class="resume-actions">
              <a href="/assets/Naman_Gupta_Resume.pdf" download class="btn btn-primary">
                📥 Download PDF
              </a>
            </div>
          </div>
          <div class="resume-sections">
            <div class="resume-section">
              <h3>⚙️ Technical Skills</h3>
              <div class="skill-list">
                <span class="bento-tag">Java</span>
                <span class="bento-tag">Spring Boot</span>
                <span class="bento-tag">Kafka</span>
                <span class="bento-tag">AWS</span>
                <span class="bento-tag">Microservices</span>
                <span class="bento-tag">Docker</span>
                <span class="bento-tag">Angular</span>
              </div>
            </div>
            <div class="resume-section">
              <h3>🏢 Experience</h3>
              <div class="experience-list">
                <div class="exp-item">
                  <h4>Senior Manager</h4>
                  <p class="company">Morgan Stanley | 2022 - Present</p>
                </div>
                <div class="exp-item">
                  <h4>Senior Software Engineer</h4>
                  <p class="company">Barclays | 2018 - 2022</p>
                </div>
                <div class="exp-item">
                  <h4>Senior Engineer</h4>
                  <p class="company">Netpulse Services | 2018</p>
                </div>
              </div>
            </div>
            <div class="resume-section">
              <h3>🎓 Education</h3>
              <div class="edu-list">
                <div class="edu-item">
                  <h4>M.Tech (Software Systems)</h4>
                  <p class="institution">BITS Pilani | 2014 - 2016</p>
                </div>
                <div class="edu-item">
                  <h4>B.Tech</h4>
                  <p class="institution">RGPV | 2009 - 2013</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .resume-page { padding-top: 100px; }
  .page-header { padding: 3rem 0; border-bottom: 1px solid var(--border-glass); }
  .page-header h1 { font-size: 2.5rem; font-weight: 700; margin-bottom: 0.5rem; }
  .page-header p { color: var(--text-secondary); }
  .resume-content { padding: 3rem 0; }
  .resume-card { padding: 2rem; max-width: 800px; margin: 0 auto; }
  .resume-info { margin-bottom: 2rem; }
  .resume-info h2 { font-size: 1.75rem; margin-bottom: 0.5rem; }
  .resume-info .title { color: var(--accent-green); font-weight: 600; margin-bottom: 0.5rem; }
  .resume-info .contact { color: var(--text-secondary); font-size: 0.9375rem; margin-bottom: 1rem; }
  .resume-info .summary { color: var(--text-secondary); line-height: 1.7; }
  .resume-actions { margin-bottom: 2rem; }
  .resume-sections { display: flex; flex-direction: column; gap: 1.5rem; }
  .resume-section h3 { font-size: 1.125rem; margin-bottom: 1rem; color: var(--text-primary); }
  .skill-list { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .bento-tag { padding: 0.375rem 0.75rem; background: var(--bg-surface); border: 1px solid var(--border-glass); border-radius: 20px; font-size: 0.8125rem; color: var(--text-secondary); font-family: var(--font-mono); }
  .experience-list, .edu-list { display: flex; flex-direction: column; gap: 1rem; }
  .exp-item h4, .edu-item h4 { font-size: 1rem; font-weight: 600; margin-bottom: 0.25rem; }
  .exp-item .company, .edu-item .institution { color: var(--text-secondary); font-size: 0.875rem; }
</style>