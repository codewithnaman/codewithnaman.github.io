---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Resume — Naman Gupta | Engineering Manager" description="Naman Gupta's resume — Engineering Manager at Mastercard with 11+ years in FinTech, Java, Kafka, AWS, AI.">
  <Header />
  <main class="resume-page">
    <section class="page-header">
      <div class="container">
        <h1>📄 Resume</h1>
        <p>Download my resume or view it below.</p>
      </div>
    </section>
    <section class="resume-content">
      <div class="container">
        <div class="resume-card glass-card">
          <div class="resume-preview">
            <div class="resume-info">
              <h2>Naman Gupta</h2>
              <p class="title">Engineering Manager</p>
              <p class="contact">📧 contact@codewithnaman.com | 📍 Pune, Maharashtra, India</p>
              <p class="contact">📱 +91 81092 04182 | 🔗 in/codewithnaman | 🌐 codewithnaman.com/</p>
              <p class="summary">
                Engineering Manager with 11+ years of experience and 8+ years in FinTech, delivering scalable and secure enterprise solutions across retail, telecom, healthcare, and financial domains. Skilled in Java, Spring, Kafka, Microservices, and AWS, with a proven track record of modernizing systems, improving performance, and mentoring teams. Passionate about leveraging AI and Cloud to solve complex challenges and drive innovation.
              </p>
            </div>
            <div class="resume-actions">
              <a href="/assets/doc/Naman_Resume_Spring_Kafka_AWS_AI_11_Yrs.pdf" download class="btn btn-primary">
                📥 Download PDF
              </a>
            </div>
          </div>
          <div class="resume-sections">
            <div class="resume-section">
              <h3>🏆 Certifications</h3>
              <div class="cert-list">
                <div class="cert-item">
                  <h4>AWS Certified Cloud Practitioner</h4>
                  <p class="cert-org">Amazon Web Services</p>
                  <p class="cert-year">2024</p>
                </div>
              </div>
            </div>
            <div class="resume-section">
              <h3>⚙️ Technical Skills</h3>
              <div class="skill-category">
                <h4>Programming Languages</h4>
                <div class="skill-list">
                  <span class="bento-tag">Java (J2SE)</span>
                  <span class="bento-tag">REST Web Services</span>
                  <span class="bento-tag">Gradle</span>
                  <span class="bento-tag">Bash</span>
                </div>
              </div>
              <div class="skill-category">
                <h4>Frameworks</h4>
                <div class="skill-list">
                  <span class="bento-tag">Spring MVC</span>
                  <span class="bento-tag">Spring JPA</span>
                  <span class="bento-tag">Spring WebFlux</span>
                  <span class="bento-tag">Spring Integration</span>
                  <span class="bento-tag">Spring Batch</span>
                  <span class="bento-tag">Hibernate</span>
                </div>
              </div>
              <div class="skill-category">
                <h4>Databases & Message Queues</h4>
                <div class="skill-list">
                  <span class="bento-tag">SQL</span>
                  <span class="bento-tag">Oracle 11g</span>
                  <span class="bento-tag">MySQL</span>
                  <span class="bento-tag">Druid</span>
                  <span class="bento-tag">Kafka</span>
                  <span class="bento-tag">MongoDB</span>
                </div>
              </div>
              <div class="skill-category">
                <h4>Cloud & DevOps</h4>
                <div class="skill-list">
                  <span class="bento-tag">AWS</span>
                  <span class="bento-tag">Docker</span>
                  <span class="bento-tag">Jenkins</span>
                  <span class="bento-tag">Sonar</span>
                  <span class="bento-tag">Grafana</span>
                  <span class="bento-tag">Prometheus</span>
                </div>
              </div>
            </div>
            <div class="resume-section">
              <h3>🏢 Experience</h3>
              <div class="experience-list">
                <div class="exp-item">
                  <h4>Manager, Software Engineering</h4>
                  <p class="company">Mastercard | Nov 2024 - Present | Pune, India</p>
                  <ul class="exp-highlights">
                    <li>Contribute to large-scale payment authentication program (3DS flow)</li>
                    <li>Translate product requirements into scalable designs (HLD/LLD)</li>
                    <li>Own end-to-end feature delivery for assigned modules</li>
                    <li>Champion AI adoption — POCs on AI agents, RAG pipelines</li>
                  </ul>
                </div>
                <div class="exp-item">
                  <h4>Technical Lead</h4>
                  <p class="company">Morgan Stanley | Feb 2022 - Nov 2024 | Bangalore, India</p>
                  <ul class="exp-highlights">
                    <li>Delivered modernized FX Incubation trading systems solutions</li>
                    <li>Built API exposure layer with FIX protocol for trading</li>
                    <li>Scaled API platform from 100 to 1000+ req/sec</li>
                    <li>Designed reconciliation system for trade data streams</li>
                  </ul>
                </div>
                <div class="exp-item">
                  <h4>Senior Software Engineer</h4>
                  <p class="company">Barclays | Oct 2018 - Feb 2022 | Pune, India</p>
                  <ul class="exp-highlights">
                    <li>Contributed to Prime Services reporting & file transfers</li>
                    <li>Migrated architecture — 30% performance improvement</li>
                    <li>Established CI/CD pipelines and code review processes</li>
                    <li>Led Database-Based Reporting solution</li>
                  </ul>
                </div>
                <div class="exp-item">
                  <h4>Senior Engineer</h4>
                  <p class="company">Netpulse Services | Apr 2018 - Sep 2018 | Pune, India</p>
                  <ul class="exp-highlights">
                    <li>Backend APIs for IoT medical devices (LifePath-C)</li>
                    <li>Designed remote patient monitoring platform APIs</li>
                    <li>Scaled application from few to thousands of customers</li>
                  </ul>
                </div>
                <div class="exp-item">
                  <h4>Senior Software Engineer</h4>
                  <p class="company">Altimetrik | Sep 2017 - Mar 2018 | Pune, India</p>
                  <ul class="exp-highlights">
                    <li>Worked with Mastercard on digital wallet project</li>
                    <li>Built backend services with secure mobile APIs</li>
                    <li>Multi-tenancy microservice architecture</li>
                  </ul>
                </div>
                <div class="exp-item">
                  <h4>Senior Software Engineer</h4>
                  <p class="company">Shiksha Infotech | Sep 2016 - Aug 2017 | Pune, India</p>
                  <ul class="exp-highlights">
                    <li>Network performance management for British Telecom</li>
                    <li>Data pipelines with Kafka and time-series databases</li>
                    <li>SNMP walks and API integrations</li>
                  </ul>
                </div>
                <div class="exp-item">
                  <h4>System Analyst</h4>
                  <p class="company">Skillnet Solutions | Dec 2014 - Aug 2016 | Indore, India</p>
                  <ul class="exp-highlights">
                    <li>PCI-compliant payment integrations for X-Store</li>
                    <li>Customized retail domain solutions</li>
                    <li>Built pluggable payment integration — 40% faster delivery</li>
                  </ul>
                </div>
              </div>
            </div>
            <div class="resume-section">
              <h3>💼 Projects</h3>
              <div class="project-list">
                <div class="project-item">
                  <h4>File Intelligent Service Hub (FISH)</h4>
                  <p>Configuration-based file transfer application supporting SFTP, SMTP, Office 365, and SMB protocols.</p>
                </div>
                <div class="project-item">
                  <h4>IoT solution for ECG device</h4>
                  <p>Mobile application APIs for IoT device data ingestion with ETL jobs for user dashboards.</p>
                </div>
                <div class="project-item">
                  <h4>Hedger Recommendation Tool for FX</h4>
                  <p>Automated data pipeline and hedging metric calculations, interactive dashboard (2-5% trade increase).</p>
                </div>
                <div class="project-item">
                  <h4>REST API for Placing Trades</h4>
                  <p>REST API tool for clients to request quotes and place orders (increased client adoption).</p>
                </div>
              </div>
            </div>
            <div class="resume-section">
              <h3>🎓 Education</h3>
              <div class="edu-list">
                <div class="edu-item">
                  <h4>Master of Technology</h4>
                  <p class="institution">Birla Institute of Technology and Science | 2014 - 2016</p>
                  <p class="specialization">Software Systems | Grade: 8.25</p>
                </div>
                <div class="edu-item">
                  <h4>Bachelor of Technology</h4>
                  <p class="institution">Sri Aurobindo Institute of Technology | 2009 - 2013</p>
                  <p class="specialization">Computer Science Engineering | Grade: 73.4%</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .resume-page { padding-top: 100px; }
  .page-header { padding: 3rem 0; border-bottom: 1px solid var(--border-glass); }
  .page-header h1 { font-size: 2.5rem; font-weight: 700; margin-bottom: 0.5rem; }
  .page-header p { color: var(--text-secondary); }
  .resume-content { padding: 3rem 0; }
  .resume-card { padding: 2rem; max-width: 800px; margin: 0 auto; }
  .resume-info { margin-bottom: 2rem; }
  .resume-info h2 { font-size: 1.75rem; margin-bottom: 0.5rem; }
  .resume-info .title { color: var(--accent-green); font-weight: 600; margin-bottom: 0.5rem; }
  .resume-info .contact { color: var(--text-secondary); font-size: 0.9375rem; margin-bottom: 0.5rem; }
  .resume-info .summary { color: var(--text-secondary); line-height: 1.7; }
  .resume-actions { margin-bottom: 2rem; }
  .resume-sections { display: flex; flex-direction: column; gap: 1.5rem; }
  .resume-section h3 { font-size: 1.125rem; margin-bottom: 1rem; color: var(--text-primary); }
  .skill-list { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
  .skill-category { margin-bottom: 1rem; }
  .skill-category h4 { font-size: 0.875rem; color: var(--text-muted); margin-bottom: 0.5rem; }
  .bento-tag { padding: 0.375rem 0.75rem; background: var(--bg-surface); border: 1px solid var(--border-glass); border-radius: 20px; font-size: 0.8125rem; color: var(--text-secondary); font-family: var(--font-mono); }
  .cert-list { display: flex; gap: 1rem; }
  .cert-item { padding: 1rem; background: var(--bg-surface); border: 1px solid var(--border-glass); border-radius: 8px; }
  .cert-item h4 { font-size: 1rem; font-weight: 600; margin-bottom: 0.25rem; }
  .cert-org { color: var(--text-secondary); font-size: 0.875rem; }
  .cert-year { color: var(--accent-green); font-size: 0.8125rem; font-family: var(--font-mono); }
  .experience-list, .edu-list { display: flex; flex-direction: column; gap: 1.5rem; }
  .exp-item h4, .edu-item h4 { font-size: 1rem; font-weight: 600; margin-bottom: 0.25rem; }
  .exp-item .company, .edu-item .institution { color: var(--text-secondary); font-size: 0.875rem; margin-bottom: 0.5rem; }
  .exp-highlights { padding-left: 1rem; margin-top: 0.5rem; }
  .exp-highlights li { color: var(--text-secondary); font-size: 0.875rem; margin-bottom: 0.25rem; }
  .specialization { font-size: 0.875rem; color: var(--accent-green); }
  .project-list { display: flex; flex-direction: column; gap: 1rem; }
  .project-item { padding: 1rem; background: var(--bg-surface); border: 1px solid var(--border-glass); border-radius: 8px; }
  .project-item h4 { font-size: 1rem; font-weight: 600; margin-bottom: 0.25rem; }
  .project-item p { color: var(--text-secondary); font-size: 0.875rem; }
</style>