---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const projects = [
  { title: "Project One", description: "A brief description of the project and what it does.", tags: ["Java", "Spring Boot", "AWS"], image: "/assets/img/portfolio/portfolio-1.jpg" },
  { title: "Project Two", description: "Another project showcasing microservices architecture.", tags: ["Microservices", "Kafka", "Docker"], image: "/assets/img/portfolio/portfolio-2.jpg" },
  { title: "Project Three", description: "Cloud-native application deployed on AWS.", tags: ["AWS", "Lambda", "React"], image: "/assets/img/portfolio/portfolio-3.jpg" },
  { title: "Project Four", description: "Real-time data processing with Kafka streams.", tags: ["Kafka", "Java", "MongoDB"], image: "/assets/img/portfolio/portfolio-4.jpg" },
  { title: "Project Five", description: "E-commerce backend with payment integration.", tags: ["Spring", "Payment Gateway", "PostgreSQL"], image: "/assets/img/portfolio/portfolio-5.jpg" },
  { title: "Project Six", description: "IoT data pipeline for medical devices.", tags: ["IoT", "Kafka", "NoSQL"], image: "/assets/img/portfolio/portfolio-6.jpg" }
];
---

<BaseLayout title="Projects | codewithnaman">
  <Header />
  <main class="projects-page">
    <section class="page-header">
      <div class="container">
        <h1><span class="accent">//</span> Projects</h1>
        <p>A collection of projects I've worked on over the years.</p>
      </div>
    </section>
    <section class="projects-grid-section">
      <div class="container">
        <div class="projects-grid">
          {projects.map(project => (
            <article class="project-card glass-card">
              <div class="project-image"><img src={project.image} alt={project.title} loading="lazy" /></div>
              <div class="project-content">
                <h3>{project.title}</h3>
                <p>{project.description}</p>
                <div class="project-tags">{project.tags.map(tag => (<span class="skill-tag">{tag}</span>))}</div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .projects-page { padding-top: 100px; }
  .page-header { padding: 4rem 0; border-bottom: 1px solid var(--border-glass); }
  .page-header h1 { font-size: 2.5rem; font-weight: 700; margin-bottom: 0.5rem; }
  .page-header .accent { font-family: var(--font-mono); color: var(--accent-green); }
  .page-header p { color: var(--text-secondary); }
  .projects-grid-section { padding: 3rem 0; }
  .projects-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; }
  .project-card { overflow: hidden; }
  .project-card:hover { border-color: var(--accent-green); transform: translateY(-4px); }
  .project-image { aspect-ratio: 16/10; overflow: hidden; }
  .project-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease; }
  .project-card:hover .project-image img { transform: scale(1.05); }
  .project-content { padding: 1.25rem; }
  .project-content h3 { font-size: 1.0625rem; font-weight: 600; margin-bottom: 0.5rem; }
  .project-content p { color: var(--text-secondary); font-size: 0.875rem; margin-bottom: 1rem; }
  .project-tags { display: flex; flex-wrap: wrap; gap: 0.375rem; }
</style>