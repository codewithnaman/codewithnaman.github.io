---
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
  { label: 'About', href: '/#about' },
  { label: 'Skills', href: '/#skills' },
  { label: 'Experience', href: '/#experience' },
  { label: 'Blog', href: 'https://blog.codewithnaman.com/' },
  { label: 'Contact', href: '/#contact' },
];
---

<header class="header">
  <nav class="nav">
    <a href="/" class="logo">
      <img src="/assets/img/cwn-logo.png" alt="CWN Logo" class="logo-img" />
    </a>
    <div class="nav-right">
      <ul class="nav-links">
        {navItems.map(item => (
          <li><a href={item.href} {...(item.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>{item.label}</a></li>
        ))}
      </ul>
      <div class="nav-icons">
        <a href="/resume" class="icon-btn" aria-label="Download Resume" title="Download Resume">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
        </a>
        <ThemeToggle />
      </div>
    </div>
  </nav>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 10, 10, 0.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border-glass);
  }

  :global([data-theme="light"]) .header {
    background: rgba(255, 255, 255, 0.85);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .nav {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
  }
  .logo-img {
    height: 36px;
    width: auto;
  }

  .logo:hover {
    opacity: 0.85;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    align-items: center;
  }

  .nav-icons {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: 1.5rem;
    padding-left: 1rem;
    border-left: 1px solid var(--border-glass);
  }

  .icon-btn {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 1px solid var(--border-glass);
    background: var(--bg-surface);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    color: var(--text-secondary);
  }

  :global([data-theme="light"]) .icon-btn {
    background: #ffffff;
    border-color: rgba(0, 0, 0, 0.15);
  }

  .icon-btn:hover {
    border-color: var(--accent-green);
    color: var(--accent-green);
    background: var(--accent-green-dim);
  }

  .nav-links a {
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 0.9375rem;
    position: relative;
    padding: 0.25rem 0;
    transition: color 0.2s ease;
  }

  :global([data-theme="light"]) .nav-links a {
    color: #1a1a1a;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--accent-green);
    transition: width 0.3s ease;
  }

  .nav-links a:hover {
    color: #ffffff;
  }

  :global([data-theme="light"]) .nav-links a:hover {
    color: var(--accent-green);
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  .resume-link {
    background: var(--accent-green);
    color: #000 !important;
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.875rem;
  }

  .resume-link:hover {
    background: var(--accent-green-hover, #16a34a);
    transform: translateY(-1px);
  }

  .resume-link::after {
    display: none;
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }

    .logo-img {
      height: 30px;
    }
  }

  @media (max-width: 480px) {
    .theme-toggle {
      display: none;
    }
  }
</style>