---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <p>&copy; {currentYear} <span class="logo-text">&lt;codewithnaman/&gt;</span></p>
    </div>
  </div>
</footer>

<style>
  .footer { padding: 2rem 0; border-top: 1px solid var(--border-glass); background: var(--bg-surface); }
  .footer-content { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
  .footer-content p { color: var(--text-muted); font-size: 0.875rem; }
  .logo-text { font-family: var(--font-mono); color: var(--accent-green); }
  @media (max-width: 480px) { .footer-content { flex-direction: column; text-align: center; } }
</style>