---
const skills = [
  { category: "Backend", items: ["Java", "Spring Boot", "Spring Core", "Spring Cloud", "REST APIs", "Microservices"], color: "blue" },
  { category: "AI & Machine Learning", items: ["AI Agents", "RAG Pipelines", "LLM Integration", "Prompt Engineering", "LoRA Fine-tuning", "Agent-to-Agent"], color: "rose" },
  { category: "Data", items: ["Kafka", "SQL", "NoSQL", "MongoDB", "PostgreSQL", "Redis"], color: "green" },
  { category: "Cloud & DevOps", items: ["AWS", "EC2", "S3", "Lambda", "Docker"], color: "amber" },
  { category: "Leadership & Management", items: ["Technical Leadership", "Team Mentoring", "Architecture Design", "CI/CD Pipelines", "Code Reviews", "Project Mgmt"], color: "teal" },
  { category: "Frontend", items: ["Angular", "React", "HTML/CSS", "TypeScript"], color: "purple" },
];
---

<section id="skills" class="skills">
  <div class="container">
    <div class="section-title">
      <h2>⚡ Skills</h2>
      <p>Over 11+ years of experience across frontend and backend development.</p>
    </div>
    <div class="bento-grid">
      {skills.map((skillCategory, index) => (
        <div class={`bento-card bento-${skillCategory.color}`} data-size={index === 0 || index === 1 ? 'large' : 'medium'}>
          <div class="bento-header">
            <span class="bento-icon">
              {skillCategory.category === 'Backend' ? '⚙️' : 
               skillCategory.category === 'AI & Machine Learning' ? '🤖' : 
               skillCategory.category === 'Data' ? '💾' : 
               skillCategory.category === 'Cloud & DevOps' ? '☁️' : 
               skillCategory.category === 'Leadership & Management' ? '👔' : '🎨'}
            </span>
            <h3>{skillCategory.category}</h3>
          </div>
          <div class="bento-tags">
            {skillCategory.items.map(skill => (
              <span class="bento-tag">{skill}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills { border-left: 3px solid var(--accent-green); }
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: minmax(140px, auto);
    gap: 1rem;
  }
  .bento-card {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: all 0.3s ease;
  }
  .bento-card:hover { transform: translateY(-4px); }
  .bento-card[data-size="large"] {
    padding: 2rem;
    border-width: 2px;
    transform: scale(1.02);
  }
  .bento-card[data-size="large"]:hover {
    transform: translateY(-4px) scale(1.02);
  }
  .bento-card[data-size="large"] .bento-header h3 {
    font-size: 1.25rem;
  }
  .bento-card[data-size="large"] .bento-icon {
    font-size: 2rem;
  }
  .bento-card[data-size="large"] .bento-tag {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
  }
  .bento-blue { background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(59, 130, 246, 0.05)); border: 1px solid rgba(59, 130, 246, 0.3); }
  .bento-blue:hover { box-shadow: 0 8px 30px rgba(59, 130, 246, 0.2); border-color: rgba(59, 130, 246, 0.5); }
  .bento-green { background: linear-gradient(135deg, rgba(34, 197, 94, 0.15), rgba(34, 197, 94, 0.05)); border: 1px solid rgba(34, 197, 94, 0.3); }
  .bento-green:hover { box-shadow: 0 8px 30px rgba(34, 197, 94, 0.2); border-color: rgba(34, 197, 94, 0.5); }
  .bento-amber { background: linear-gradient(135deg, rgba(245, 158, 11, 0.15), rgba(245, 158, 11, 0.05)); border: 1px solid rgba(245, 158, 11, 0.3); }
  .bento-amber:hover { box-shadow: 0 8px 30px rgba(245, 158, 11, 0.2); border-color: rgba(245, 158, 11, 0.5); }
  .bento-purple { background: linear-gradient(135deg, rgba(168, 85, 247, 0.15), rgba(168, 85, 247, 0.05)); border: 1px solid rgba(168, 85, 247, 0.3); }
  .bento-purple:hover { box-shadow: 0 8px 30px rgba(168, 85, 247, 0.2); border-color: rgba(168, 85, 247, 0.5); }
  .bento-teal { background: linear-gradient(135deg, rgba(20, 184, 166, 0.15), rgba(20, 184, 166, 0.05)); border: 1px solid rgba(20, 184, 166, 0.3); }
  .bento-teal:hover { box-shadow: 0 8px 30px rgba(20, 184, 166, 0.2); border-color: rgba(20, 184, 166, 0.5); }
  .bento-rose { background: linear-gradient(135deg, rgba(244, 63, 94, 0.15), rgba(244, 63, 94, 0.05)); border: 1px solid rgba(244, 63, 94, 0.3); }
  .bento-rose:hover { box-shadow: 0 8px 30px rgba(244, 63, 94, 0.2); border-color: rgba(244, 63, 94, 0.5); }
  .bento-blue.bento-card[data-size="large"] { box-shadow: 0 0 20px rgba(59, 130, 246, 0.3), 0 8px 30px rgba(0, 0, 0, 0.4); }
  .bento-blue.bento-card[data-size="large"]:hover { box-shadow: 0 0 30px rgba(59, 130, 246, 0.5), 0 12px 40px rgba(0, 0, 0, 0.5); }
  .bento-rose.bento-card[data-size="large"] { box-shadow: 0 0 20px rgba(244, 63, 94, 0.3), 0 8px 30px rgba(0, 0, 0, 0.4); }
  .bento-rose.bento-card[data-size="large"]:hover { box-shadow: 0 0 30px rgba(244, 63, 94, 0.5), 0 12px 40px rgba(0, 0, 0, 0.5); }
  .bento-header { display: flex; align-items: center; gap: 0.75rem; }
  .bento-icon { font-size: 1.5rem; }
  .bento-header h3 { font-size: 1.125rem; font-weight: 600; color: var(--text-primary); }
  .bento-blue .bento-header h3 { color: var(--accent-blue); }
  .bento-green .bento-header h3 { color: var(--accent-green); }
  .bento-amber .bento-header h3 { color: var(--accent-amber); }
  .bento-purple .bento-header h3 { color: var(--accent-purple); }
  .bento-teal .bento-header h3 { color: #14b8a6; }
  .bento-rose .bento-header h3 { color: #f43f5e; }
  .bento-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .bento-tag { padding: 0.375rem 0.75rem; background: rgba(255,255,255,0.1); border-radius: 20px; font-size: 0.8125rem; color: var(--text-secondary); font-family: var(--font-mono); }
  @media (max-width: 768px) {
    .bento-grid { grid-template-columns: 1fr; }
  }
</style>