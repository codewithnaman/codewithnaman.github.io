<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 80px;
    position: relative;
    overflow: hidden;
  }

  .hero-content {
    animation: fadeInUp 0.8s ease forwards;
  }

  .terminal-prompt {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    margin-bottom: 1.5rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .prompt-symbol {
    color: var(--accent-green);
    font-weight: 600;
  }

  .prompt-text {
    color: var(--text-secondary);
  }

  .name {
    font-size: 4rem;
    font-weight: 800;
    line-height: 1.05;
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
  }

  .name-text {
    background: linear-gradient(135deg, var(--accent-green) 0%, var(--accent-blue) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .role-container {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .role-label {
    color: var(--text-secondary);
    font-size: 1.25rem;
  }

  .role-typewriter {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    color: var(--accent-green);
    font-weight: 500;
  }

  .cursor {
    color: var(--accent-green);
    font-weight: 400;
    animation: blink 1s infinite;
  }

  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  .tagline {
    max-width: 540px;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.7;
    font-size: 1.0625rem;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .hero-social {
    display: flex;
    gap: 0.75rem;
  }

  @media (max-width: 768px) {
    .name {
      font-size: 2.5rem;
    }

    .role-container {
      flex-direction: column;
      align-items: flex-start;
    }

    .hero-cta {
      flex-direction: column;
    }

    .hero-cta .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script>
  const roles = ['AI Enthusiast', 'Engineering Manager', 'Software Engineer', 'Solution Architect', 'Backend Developer', 'Trainer'];
  const typewriter = document.getElementById('typewriter');
  let roleIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  let typeSpeed = 80;

  function typeWriter() {
    const currentRole = roles[roleIndex];

    if (isDeleting) {
      typewriter.textContent = currentRole.substring(0, charIndex - 1);
      charIndex--;
      typeSpeed = 40;
    } else {
      typewriter.textContent = currentRole.substring(0, charIndex + 1);
      charIndex++;
      typeSpeed = 80;
    }

    if (!isDeleting && charIndex === currentRole.length) {
      typeSpeed = 2000;
      isDeleting = true;
    } else if (isDeleting && charIndex === 0) {
      isDeleting = false;
      roleIndex = (roleIndex + 1) % roles.length;
      typeSpeed = 500;
    }

    setTimeout(typeWriter, typeSpeed);
  }

  document.addEventListener('DOMContentLoaded', typeWriter);
</script>