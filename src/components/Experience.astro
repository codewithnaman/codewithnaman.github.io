---
const experience = [
  {
    company: "Morgan Stanley",
    location: "Bangalore, India",
    role: "Senior Manager",
    period: "2022 - Present",
    highlights: [
      "✅ Design & develop applications for new business ventures",
      "🎯 Propose architectural improvements for clean architecture",
      "🚀 Conduct POCs and transform POC code to production"
    ]
  },
  {
    company: "Barclays",
    location: "Pune, India",
    role: "Senior Software Engineer",
    period: "2018 - 2022",
    highlights: [
      "✅ Developed features for 10+ year old application",
      "🚀 Migrated architecture - 30% performance, 20% cost reduction",
      "🎯 Established CI/CD pipeline and code standards"
    ]
  },
  {
    company: "Netpulse Services",
    location: "Pune, India",
    role: "Senior Engineer",
    period: "2018",
    highlights: [
      "✅ Backend APIs for IoT medical data transmission",
      "💾 Processed millions of records/hour using Kafka"
    ]
  },
  {
    company: "Altimetrik",
    location: "Pune, India",
    role: "Senior Software Engineer",
    period: "2017 - 2018",
    highlights: [
      "✅ Backend developer for large-scale project",
      "💡 Built wallet APIs for banks and merchants"
    ]
  },
  {
    company: "Shiksha Infotech",
    location: "Pune, India",
    role: "Senior Software Engineer",
    period: "2016 - 2017",
    highlights: [
      "✅ Big Data tech (Kafka, NoSQL) enhancements",
      "🎯 High-volume data processing solutions"
    ]
  },
  {
    company: "Skillnet Solutions",
    location: "Indore, India",
    role: "System Analyst",
    period: "2014 - 2016",
    highlights: [
      "✅ Customized X-Store for various clients",
      "🚀 PCI-compliant payment solution - 40% faster delivery"
    ]
  }
];

const education = [
  { degree: "M.Tech (Software Systems)", institution: "BITS Pilani", period: "2014 - 2016", specialization: "🎓 Data Science" },
  { degree: "B.Tech", institution: "RGPV", period: "2009 - 2013", specialization: "🎓 Computer Science" }
];
---

<section id="experience" class="experience">
  <div class="container">
    <div class="section-title">
      <h2>📋 Experience</h2>
    </div>
    <div class="timeline">
      {experience.map((job) => (
        <div class="timeline-item glass-card">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <div class="timeline-header">
              <h3>{job.role}</h3>
              <span class="period">{job.period}</span>
            </div>
            <p class="company">🏢 {job.company}, {job.location}</p>
            <ul class="highlights">
              {job.highlights.map(highlight => (
                <li>{highlight}</li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
    <div class="section-title" style="margin-top: 3rem;">
      <h2>🎓 Education</h2>
    </div>
    <div class="education-grid">
      {education.map(edu => (
        <div class="education-item glass-card">
          <h3>{edu.degree}</h3>
          <p class="institution">🏛️ {edu.institution}</p>
          <p class="period">{edu.period}</p>
          <p class="specialization">{edu.specialization}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .experience { border-left: 3px solid var(--accent-amber); }
  .timeline { position: relative; padding-left: 2rem; }
  .timeline::before { content: ''; position: absolute; left: 6px; top: 0; bottom: 0; width: 2px; background: var(--border-glass); }
  .timeline-item { position: relative; margin-bottom: 1.5rem; padding: 1.5rem; margin-left: 1rem; }
  .timeline-marker { position: absolute; left: -2.55rem; top: 50%; width: 12px; height: 12px; border-radius: 50%; background: var(--accent-amber); box-shadow: 0 0 12px var(--accent-amber); border: 2px solid var(--bg-secondary); transform: translate(-50%, -50%); }
  .timeline-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem; flex-wrap: wrap; gap: 0.5rem; }
  .timeline-header h3 { font-size: 1.0625rem; font-weight: 600; }
  .period { font-size: 0.8125rem; color: var(--accent-amber); font-family: var(--font-mono); }
  .company { color: var(--text-secondary); margin-bottom: 0.75rem; font-weight: 500; }
  .highlights { list-style: none; padding: 0; }
  .highlights li { margin-bottom: 0.375rem; color: var(--text-secondary); font-size: 0.875rem; }
  .education-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  .education-item { padding: 1.5rem; }
  .education-item h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; }
  .institution { color: var(--text-secondary); font-weight: 500; }
  .education-item .period { font-size: 0.8125rem; }
  .specialization { font-size: 0.875rem; color: var(--accent-green); margin-top: 0.5rem; }
  @media (max-width: 768px) { .education-grid { grid-template-columns: 1fr; } }
</style>