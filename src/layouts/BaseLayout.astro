---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Lead Software Engineer with 11+ years experience in FinTech. Building scalable systems with Java, Spring, Kafka & Cloud. AI enthusiast and engineering leader." } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    
    <!-- Open Graph (Facebook, LinkedIn) -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://codewithnaman.com${Astro.url.pathname}`} />
    <meta property="og:image" content="https://codewithnaman.com/assets/img/profile-img.jpg" />
    <meta property="og:site_name" content="codewithnaman" />
    <meta property="og:locale" content="en_US" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://codewithnaman.com/assets/img/profile-img.jpg" />
    <meta name="twitter:creator" content="@codewithnaman" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={`https://codewithnaman.com${Astro.url.pathname}`} />
    
    <link rel="icon" type="image/svg+xml" href="/assets/img/favicon-32x32.png" />
    <title>{title}</title>
    
    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Naman Gupta",
        "url": "https://codewithnaman.com",
        "image": "https://codewithnaman.com/assets/img/profile-img.jpg",
        "jobTitle": "Lead Software Engineer",
        "worksFor": {
          "@type": "Organization",
          "name": "Mastercard"
        },
        "sameAs": [
          "https://www.linkedin.com/in/codewithnaman",
          "https://twitter.com/codewithnaman",
          "https://github.com/codewithnaman"
        ],
        "description": "Lead Software Engineer with 11+ years in FinTech. AI enthusiast and engineering leader.",
        "knowsAbout": ["Java", "Spring Framework", "Kafka", "AWS Cloud", "AI", "Microservices"]
      }
    </script>
  </head>
  <body>
    <div class="grid-bg"></div>
    <slot />
    <script is:inline>
      const theme = localStorage.getItem('theme') ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>